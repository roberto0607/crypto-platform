# ── Required ──
DATABASE_URL=postgresql://cp:cp@localhost:5433/cp
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string

# ── Server ──
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT ──
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# ── Redis (optional — omit for in-memory fallback) ──
# REDIS_URL=redis://localhost:6379

# ── Instance (multi-instance deployment) ──
# INSTANCE_ID=api-1
# INSTANCE_ROLE=ALL  # API | WORKER | ALL

# ── Database Pool ──
# DB_POOL_MAX=20
# DB_SLOW_QUERY_MS=200

# ── Feature Flags ──
# DISABLE_RATE_LIMIT=false
# DISABLE_JOB_RUNNER=false
# BETA_MODE=false
# LOAD_SHEDDING_ENABLED=true
# RUN_MIGRATIONS_ON_BOOT=false

# ── Security ──
# MAX_LOGIN_ATTEMPTS_PER_EMAIL=5
# MAX_LOGIN_ATTEMPTS_PER_IP=20
# LOGIN_BLOCK_WINDOW_MINUTES=15
# MAX_API_KEY_REQ_PER_MIN=120

# ── Queue ──
# MAX_QUEUE_DEPTH=100
# QUEUE_TIMEOUT_MS=5000

# ── Outbox Worker ──
# OUTBOX_WORKER_ENABLED=true
# OUTBOX_BATCH_SIZE=50
# OUTBOX_POLL_INTERVAL_MS=1000
