{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "auth:smoke": "bash scripts/auth-smoke.sh",
    "test": "vitest run && tsx scripts/seed-dev-user.ts",
    "dev:me": "tsx scripts/seed-dev-user.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cleanup:tokens": "tsx src/scripts/cleanupRefreshTokens.ts",
    "dev:seed": "bash scripts/seed.sh",
    "dev:reset": "bash scripts/reset.sh --force",
    "dev:demo": "bash scripts/demo.sh",
    "dev:sandbox": "bash scripts/reset.sh --force && bash scripts/seed.sh && bash scripts/demo.sh",
    "restore:drill": "bash scripts/restore-drill.sh",
    "dev:db-reset": "psql $DATABASE_URL -f scripts/dev-reset.sql",
    "seed:loadtest": "tsx scripts/seed-loadtest.ts",
    "load:auth": "k6 run load/k6/scenario_auth_smoke.js",
    "load:reads": "k6 run load/k6/scenario_read_heavy.js",
    "load:writes": "k6 run load/k6/scenario_trade_burst.js",
    "load:mixed": "k6 run load/k6/scenario_mixed_realistic.js",
    "load:outbox": "k6 run load/k6/scenario_outbox_pressure.js",
    "load:all": "pnpm load:auth && pnpm load:reads && pnpm load:writes && pnpm load:mixed && pnpm load:outbox",
    "openapi": "tsx src/scripts/generateOpenapi.ts",
    "backfill": "tsx src/scripts/backfillCandles.ts",
    "seed": "tsx src/sandbox/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.0",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
