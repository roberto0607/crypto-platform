        {
          "expr": "rate(orders_created_total[1m]) * 60",
          "legendFormat": "orders/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
